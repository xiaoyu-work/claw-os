#!/usr/bin/env python3
"""aos-ctl — Host-side management tool for Agent OS instances.

Usage:
    aos-ctl build                          Build the rootfs
    aos-ctl run [--name N] [--port P] [--workspace DIR]
                                           Start a container instance
    aos-ctl list                           List running instances
    aos-ctl stop <id>                      Stop an instance
    aos-ctl shell <id>                     Attach a shell to an instance
    aos-ctl exec <id> <aos-command...>     Run an aos command inside an instance
    aos-ctl logs <id>                      Show container logs
    aos-ctl image                          Show image info
    aos-ctl status                         Show system status
"""

import json
import os
import subprocess
import sys

PROJECT_DIR = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
IMAGE_NAME = "agent-os"
CONTAINER_PREFIX = "aos-"


def respond(data):
    if "ok" not in data:
        data["ok"] = "error" not in data
    json.dump(data, sys.stdout, indent=2)
    print()


def error(msg):
    respond({"ok": False, "error": msg})
    sys.exit(1)


def docker(*args, capture=True):
    cmd = ["docker"] + list(args)
    if capture:
        result = subprocess.run(cmd, capture_output=True, text=True)
        return result
    else:
        return subprocess.run(cmd)


def cmd_build(_args):
    """Build the rootfs and Docker image."""
    rootfs = os.path.join(PROJECT_DIR, "build", "agent-os-rootfs")
    if not os.path.isdir(rootfs):
        error(f"rootfs not found at {rootfs} — run: sudo ./rootfs/build.sh")

    result = docker(
        "build",
        "-f", os.path.join(PROJECT_DIR, "docker", "Dockerfile"),
        "-t", IMAGE_NAME,
        PROJECT_DIR,
    )
    if result.returncode != 0:
        error(f"docker build failed:\n{result.stderr}")
    respond({"image": IMAGE_NAME, "status": "built"})


def cmd_run(args):
    """Start a new Agent OS container."""
    name = None
    port = None
    workspace = None
    i = 0
    while i < len(args):
        if args[i] == "--name" and i + 1 < len(args):
            name = args[i + 1]
            i += 2
        elif args[i] == "--port" and i + 1 < len(args):
            port = args[i + 1]
            i += 2
        elif args[i] == "--workspace" and i + 1 < len(args):
            workspace = args[i + 1]
            i += 2
        else:
            i += 1

    if name is None:
        import uuid
        name = CONTAINER_PREFIX + uuid.uuid4().hex[:8]
    else:
        name = CONTAINER_PREFIX + name

    docker_args = [
        "run", "-d",
        "--name", name,
        "--hostname", "agent-os",
    ]

    if port is not None:
        docker_args += ["-p", f"{port}:{port}"]

    if workspace is not None:
        docker_args += ["-v", f"{workspace}:/workspace"]

    docker_args += [IMAGE_NAME, "sleep", "infinity"]

    result = docker(*docker_args)
    if result.returncode != 0:
        error(f"failed to start: {result.stderr.strip()}")

    container_id = result.stdout.strip()[:12]
    info = {"id": container_id, "name": name, "status": "running"}
    if port is not None:
        info["port"] = port
    if workspace is not None:
        info["workspace"] = workspace
    respond(info)


def cmd_list(_args):
    """List running Agent OS containers."""
    result = docker(
        "ps", "--filter", f"ancestor={IMAGE_NAME}",
        "--format", '{{.ID}}\t{{.Names}}\t{{.Status}}',
    )
    instances = []
    for line in result.stdout.strip().splitlines():
        if not line:
            continue
        parts = line.split("\t")
        instances.append({
            "id": parts[0],
            "name": parts[1] if len(parts) > 1 else "",
            "status": parts[2] if len(parts) > 2 else "",
        })
    respond({"instances": instances})


def cmd_stop(args):
    """Stop an Agent OS container."""
    if not args:
        error("usage: aos-ctl stop <id|name>")
    target = args[0]
    result = docker("stop", target)
    if result.returncode != 0:
        error(f"failed to stop: {result.stderr.strip()}")
    docker("rm", target)
    respond({"stopped": target})


def cmd_shell(args):
    """Attach a shell to a running instance."""
    if not args:
        error("usage: aos-ctl shell <id|name>")
    docker("exec", "-it", args[0], "/bin/bash", "--login", capture=False)


def cmd_exec(args):
    """Run an aos command inside an instance."""
    if len(args) < 2:
        error("usage: aos-ctl exec <id|name> <aos-command...>")
    target = args[0]
    aos_args = args[1:]
    result = docker("exec", target, "aos", *aos_args)
    # Pass through the JSON output from aos directly
    if result.stdout.strip():
        try:
            data = json.loads(result.stdout)
            if "ok" not in data:
                data["ok"] = "error" not in data
            json.dump(data, sys.stdout, indent=2)
            print()
        except json.JSONDecodeError:
            respond({
                "ok": result.returncode == 0,
                "instance": target,
                "output": result.stdout,
            })
    else:
        respond({
            "ok": result.returncode == 0,
            "instance": target,
            "command": aos_args,
            "exit_code": result.returncode,
            "stderr": result.stderr,
        })
    if result.returncode != 0:
        sys.exit(result.returncode)


def cmd_logs(args):
    """Show container logs."""
    if not args:
        error("usage: aos-ctl logs <id|name>")
    target = args[0]
    result = docker("logs", target)
    if result.returncode != 0:
        error(f"failed to get logs: {result.stderr.strip()}")
    respond({
        "instance": target,
        "stdout": result.stdout,
        "stderr": result.stderr,
    })


def cmd_image(_args):
    """Show image info (size, created date)."""
    result = docker(
        "images", IMAGE_NAME,
        "--format", '{{.Size}}\t{{.CreatedAt}}\t{{.ID}}\t{{.Tag}}',
    )
    if result.returncode != 0 or not result.stdout.strip():
        error(f"image '{IMAGE_NAME}' not found")
    line = result.stdout.strip().splitlines()[0]
    parts = line.split("\t")
    respond({
        "image": IMAGE_NAME,
        "size": parts[0] if len(parts) > 0 else "",
        "created": parts[1] if len(parts) > 1 else "",
        "id": parts[2] if len(parts) > 2 else "",
        "tag": parts[3] if len(parts) > 3 else "",
    })


def cmd_status(_args):
    """Show Agent OS system status."""
    # Check if image exists
    result = docker("images", IMAGE_NAME, "--format", "{{.Size}}")
    image_exists = bool(result.stdout.strip())

    # Count running containers
    result = docker("ps", "-q", "--filter", f"ancestor={IMAGE_NAME}")
    running = len(result.stdout.strip().splitlines()) if result.stdout.strip() else 0

    rootfs = os.path.join(PROJECT_DIR, "build", "agent-os-rootfs")
    respond({
        "image": IMAGE_NAME if image_exists else None,
        "rootfs_exists": os.path.isdir(rootfs),
        "running_instances": running,
    })


COMMANDS = {
    "build":  cmd_build,
    "run":    cmd_run,
    "list":   cmd_list,
    "stop":   cmd_stop,
    "shell":  cmd_shell,
    "exec":   cmd_exec,
    "logs":   cmd_logs,
    "image":  cmd_image,
    "status": cmd_status,
}


def main():
    args = sys.argv[1:]

    if not args or args[0] in ("-h", "--help"):
        respond({
            "name": "aos-ctl",
            "commands": sorted(COMMANDS.keys()),
        })
        return

    cmd = args[0]
    handler = COMMANDS.get(cmd)
    if handler is None:
        error(f"unknown command: {cmd}")

    handler(args[1:])


if __name__ == "__main__":
    main()
