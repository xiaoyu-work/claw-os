#!/usr/bin/env python3
"""aos — Agent OS command router.

Discovers installed apps and routes commands to them.
All output is JSON. All errors set a non-zero exit code.

Usage:
    aos                          List installed apps
    aos <app> <command> [args]   Run an app command
    aos <app>                    Show app help
"""

import importlib.util
import json
import os
import sys

VERSION = "0.3.0"
APPS_DIR = os.environ.get("AOS_APPS_DIR", "/usr/lib/aos/apps")
DATA_DIR = os.environ.get("AOS_DATA_DIR", "/var/lib/aos")


def respond(data):
    json.dump(data, sys.stdout)
    print()


def error(msg, code=1):
    respond({"error": msg})
    sys.exit(code)


def discover_apps():
    """Scan apps directory and return {name: manifest} for each valid app."""
    apps = {}
    if not os.path.isdir(APPS_DIR):
        return apps
    for name in sorted(os.listdir(APPS_DIR)):
        manifest_path = os.path.join(APPS_DIR, name, "app.json")
        if os.path.isfile(manifest_path):
            try:
                with open(manifest_path) as f:
                    apps[name] = json.load(f)
            except (json.JSONDecodeError, OSError):
                pass
    return apps


def load_app_module(app_name):
    """Load an app's main.py as a module."""
    main_path = os.path.join(APPS_DIR, app_name, "main.py")
    if not os.path.isfile(main_path):
        error(f"app '{app_name}' has no main.py")
    spec = importlib.util.spec_from_file_location(f"aos_app_{app_name}", main_path)
    mod = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(mod)
    return mod


def run_app_command(app_name, command, args):
    """Load app and call its run(command, args) function."""
    mod = load_app_module(app_name)
    if not hasattr(mod, "run"):
        error(f"app '{app_name}' missing run() function")
    try:
        result = mod.run(command, args)
    except SystemExit:
        raise
    except Exception as e:
        error(f"{app_name} {command}: {e}")
    if result is not None:
        respond(result)


def show_apps():
    """List all installed apps."""
    apps = discover_apps()
    app_list = []
    for name, manifest in apps.items():
        app_list.append({
            "name": name,
            "description": manifest.get("description", ""),
            "commands": list(manifest.get("commands", {}).keys()),
        })
    respond({"name": "aos", "version": VERSION, "apps": app_list})


def show_app_help(app_name, apps):
    """Show help for a specific app."""
    manifest = apps[app_name]
    respond({
        "app": app_name,
        "version": manifest.get("version", ""),
        "description": manifest.get("description", ""),
        "commands": manifest.get("commands", {}),
    })


def main():
    args = sys.argv[1:]

    if not args:
        show_apps()
        return

    app_name = args[0]
    apps = discover_apps()

    if app_name not in apps:
        error(f"unknown app: {app_name}. installed: {list(apps.keys())}")

    # One arg: show app help
    if len(args) == 1:
        show_app_help(app_name, apps)
        return

    command = args[1]
    cmd_args = args[2:]

    # Validate command exists
    valid_commands = apps[app_name].get("commands", {})
    if command not in valid_commands:
        error(f"unknown command: {app_name} {command}. available: {list(valid_commands.keys())}")

    run_app_command(app_name, command, cmd_args)


if __name__ == "__main__":
    main()
