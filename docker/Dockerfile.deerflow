FROM ghcr.io/xiaoyu-work/claw-os:latest

# DeerFlow requires Python 3.12+ (Debian Bookworm ships 3.11)
RUN apt-get update -qq \
    && apt-get install -y --no-install-recommends \
       software-properties-common \
    && echo "deb http://deb.debian.org/debian trixie main" > /etc/apt/sources.list.d/trixie.list \
    && apt-get update -qq \
    && apt-get install -y --no-install-recommends -t trixie python3.12 python3.12-venv python3.12-dev \
    && rm /etc/apt/sources.list.d/trixie.list \
    && apt-get update -qq \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Install uv (Python package manager) and pnpm
RUN pip3 install --break-system-packages uv \
    && npm install -g pnpm

# Install DeerFlow
RUN git clone --depth 1 https://github.com/bytedance/deer-flow.git /opt/deer-flow \
    && cd /opt/deer-flow/backend && uv sync \
    && cd /opt/deer-flow/frontend && pnpm install && pnpm build

# Copy Claw OS skill into DeerFlow's custom skills
COPY skills/claw-os /opt/deer-flow/skills/custom/claw-os

WORKDIR /opt/deer-flow

ENTRYPOINT ["/usr/local/bin/cos-init"]
CMD ["make", "start"]
